# Configuration Blueprint
STELLAR_SECRET_KEY=
STELLAR_NETWORK=testnet

# Stellar Horizon URLs (comma-separated for failover)
STELLAR_HORIZON_URLS=
STELLAR_RPC_URLS=

# Service-to-service JWT auth
# Must be at least 32 characters. Rotate periodically.
JWT_SIGNING_SECRET=change-me-to-a-strong-random-secret-min-32-chars
JWT_ISSUER=vero-relayer-service

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=change-me
REDIS_TLS=false
EVENT_QUEUE_NAME=vero:event-processing
EVENT_QUEUE_CONCURRENCY=5
EVENT_PAYLOAD_RETENTION_DAYS=7

# Rate limiting configuration (IP-based)
# Window in milliseconds for rate limiting (default 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window for unauthenticated/public clients
RATE_LIMIT_PUBLIC_MAX=100
# Maximum requests per window for authenticated clients (JWT/HMAC)
RATE_LIMIT_AUTH_MAX=1000

# OpenTelemetry / tracing
OTEL_SERVICE_NAME=vero-relayer-service
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SDK_DISABLED=false
